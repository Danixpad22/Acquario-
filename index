<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🏠 App Gestione Acquario Marino 180L</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif; background: linear-gradient(135deg,#0a3d62 0%,#1e5f8b 100%); color: #fff; min-height: 100vh; }
        .container { max-width: 1200px; margin: 0 auto; padding: 20px; }
        .header { text-align: center; margin-bottom: 30px; }
        .header h1 { font-size: 2.2em; margin-bottom: 10px; background: linear-gradient(45deg,#ff6b35,#f7931e); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .status-grid { display: grid; grid-template-columns: repeat(auto-fit,minmax(280px,1fr)); gap: 20px; margin-bottom: 30px; }
        .card { background: rgba(255,255,255,0.1); backdrop-filter: blur(20px); border-radius: 20px; padding: 25px; border: 1px solid rgba(255,255,255,0.2); }
        .card h3 { color: #ffeb3b; margin-bottom: 15px; font-size: 1.3em; }
        .urgent { border-left: 5px solid #ff4444; animation: pulse 2s infinite; }
        .warning { border-left: 5px solid #ffaa00; }
        .good { border-left: 5px solid #00ff88; }
        @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.5} }
        .check-btn { background: linear-gradient(45deg,#00ff88,#00cc66); border: none; padding: 15px 25px; border-radius: 50px; color: #000; font-weight: bold; font-size: 1.1em; cursor: pointer; transition: all 0.3s; width: 100%; margin: 10px 0; }
        .check-btn:hover { transform: scale(1.05); box-shadow: 0 10px 30px rgba(0,255,136,0.4); }
        .check-btn.completed { background: linear-gradient(45deg,#666,#444); cursor: not-allowed; }
        .param-row { display: grid; grid-template-columns: 1fr 120px 80px; gap: 15px; margin: 10px 0; padding: 12px; background: rgba(255,255,255,0.05); border-radius: 10px; }
        .checklist-grid { display: grid; grid-template-columns: repeat(auto-fit,minmax(200px,1fr)); gap: 15px; margin-top: 20px; }
        .day-check { background: rgba(255,255,255,0.1); padding: 15px; border-radius: 15px; text-align: center; cursor: pointer; transition: all 0.3s; }
        .day-check:hover { background: rgba(255,255,255,0.2); transform: translateY(-3px); }
        .day-check.completed { background: linear-gradient(45deg,#00ff88,#00cc66); color: #000; }
        .log-table { width: 100%; border-collapse: collapse; margin-top: 20px; background: rgba(255,255,255,0.1); border-radius: 15px; overflow: hidden; }
        .log-table th, .log-table td { padding: 12px; text-align: left; border-bottom: 1px solid rgba(255,255,255,0.1); }
        .log-table th { background: rgba(255,255,255,0.2); }
        .export-btn { background: linear-gradient(45deg,#ff6b35,#f7931e); color: white; border: none; padding: 12px 24px; border-radius: 25px; cursor: pointer; margin-top: 20px; font-weight: bold; }
        @media (max-width: 768px) { .status-grid { grid-template-columns: 1fr; } .param-row { grid-template-columns: 2fr 1fr; font-size: 0.9em; } }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>🏠 Acquario Marino 180L</h1>
            <p>Damigella + Coralli Molli/LPS | Deltec I-600 | GNC AM 366</p>
            <div id="data_corrente"></div>
        </div>

        <div class="status-grid" id="statusGrid">
            <!-- Status dinamici caricati da localStorage -->
        </div>

        <div class="card">
            <h3>📋 Checklist Settimanale (24-30 Mar 2026)</h3>
            <div class="checklist-grid" id="checklistSettimanale"></div>
        </div>

        <div class="card">
            <h3>📅 Manutenzioni Critiche</h3>
            <div id="manutenzioniCritiche">
                <div class="param-row">
                    <strong>Cambio Acqua Settimanale</strong>
                    <span id="acquaStatus">Prossimo: 31/03 🟡</span>
                    <button class="check-btn" onclick="checkCompleto('acqua_settimanale')">Spunta Cambio Acqua ✅</button>
                </div>
                <div class="param-row urgent">
                    <strong>Resine Osmosi</strong>
                    <span id="resineStatus">URGENTE! Scaduto 🔴</span>
                    <button class="check-btn" onclick="checkCompleto('resine_osmosi')">Spunta Resine ✅</button>
                </div>
            </div>
        </div>

        <div class="card">
            <h3>📊 Ultimi Check Completati</h3>
            <table class="log-table" id="logTabella"></table>
            <button class="export-btn" onclick="esportaLog()">📥 Esporta CSV</button>
        </div>
    </div>

    <script>
        // Inizializzazione app
        let appData = {
            dataCorrente: new Date('2026-03-24'),
            checklistSettimanale: {
                lun: {completo: true, label: 'Alimentazione + Rabbocco'},
                mar: {completo: true, label: 'Vetri + Parametri'},
                mer: {completo: false, label: 'Skimmer Deltec'},
                gio: {completo: false, label: 'Pompe Movimento'},
                ven: {completo: false, label: 'Nutrimento Coralli'},
                sab: {completo: false, label: 'Test Completi'},
                dom: {completo: false, label: 'Cambio Acqua 10%'}
            },
            logManutenzione: [
                {data: '24/03/2026', tipo: 'Cambio Acqua', note: '10% completato', prossimo: '31/03/2026', giorni: 7},
                {data: '17/03/2026', tipo: 'Skimmer Pulizia', note: 'Pompa DC OK', prossimo: '24/03/2026', giorni: 0}
            ],
            ultimicambi: {acqua: '24/03/2026', resine: '15/07/2025'}
        };

        // Carica/salva dati localStorage
        function initApp() {
            if(localStorage.getItem('acquarioData')) {
                appData = JSON.parse(localStorage.getItem('acquarioData'));
            }
            aggiornaInterfaccia();
            document.getElementById('data_corrente').textContent = `Data: ${appData.dataCorrente.toLocaleDateString('it-IT')}`;
        }

        function aggiornaInterfaccia() {
            aggiornaStatus();
            renderChecklist();
            renderLog();
        }

        function checkCompleto(tipo) {
            const ora = new Date();
            let prossimo = '';
            let giorni = 0;

            if(tipo === 'acqua_settimanale') {
                prossimo = new Date(ora.getTime() + 7*24*60*60*1000).toLocaleDateString('it-IT');
                appData.checklistSettimanale.dom.completo = true;
                appData.ultimicambi.acqua = ora.toLocaleDateString('it-IT');
            } else if(tipo === 'resine_osmosi') {
                prossimo = new Date(ora.getTime() + 240*24*60*60*1000).toLocaleDateString('it-IT');
                appData.ultimicambi.resine = ora.toLocaleDateString('it-IT');
            }

            // Aggiungi al log
            appData.logManutenzione.unshift({
                data: ora.toLocaleDateString('it-IT'),
                tipo: tipo.replace('_',' ').toUpperCase(),
                note: `Completato ${ora.toLocaleTimeString('it-IT')}`,
                prossimo: prossimo,
                giorni: giorni
            });

            localStorage.setItem('acquarioData', JSON.stringify(appData));
            aggiornaInterfaccia();
        }

        function aggiornaStatus() {
            const grid = document.getElementById('statusGrid');
            grid.innerHTML = `
                <div class="card ${getStatusClass('acqua')}">
                    <h3>💧 Cambio Acqua</h3>
                    <p>Ultimo: ${appData.ultimicambi.acqua || 'Mai'}</p>
                    <p id="acquaStatus">Prossimo: ${calcolaProssimo('acqua')}</p>
                </div>
                <div class="card ${getStatusClass('resine')}">
                    <h3>🔬 Resine Osmosi</h3>
                    <p>Ultimo: ${appData.ultimicambi.resine || 'Mai'}</p>
                    <p id="resineStatus">Prossimo: ${calcolaProssimo('resine')}</p>
                </div>
            `;
        }

        function getStatusClass(tipo) {
            const giorni = calcolaGiorniRimanenti(tipo);
            if(giorni <= 0) return 'urgent';
            if(giorni <= 7) return 'warning';
            return 'good';
        }

        function calcolaGiorniRimanenti(tipo) {
            // Logica semplificata per demo
            return tipo === 'acqua' ? 7 : 0;
        }

        function calcolaProssimo(tipo) {
            const giorni = calcolaGiorniRimanenti(tipo);
            const emoji = giorni <= 0 ? '🔴' : giorni <= 7 ? '🟡' : '🟢';
            return `${emoji} ${giorni}gg`;
        }

        function renderChecklist() {
            const grid = document.getElementById('checklistSettimanale');
            grid.innerHTML = Object.entries(appData.checklistSettimanale).map(([giorno, dati]) => 
                `<div class="day-check ${dati.completo ? 'completed' : ''}" onclick="spuntaGiorno('${giorno}')">
                    <strong>${giorno.toUpperCase()}</strong><br>
                    ${dati.label}<br>
                    ${dati.completo ? '✅' : '⏳'}
                </div>`
            ).join('');
        }

        function spuntaGiorno(giorno) {
            appData.checklistSettimanale[giorno].completo = true;
            localStorage.setItem('acquarioData', JSON.stringify(appData));
            aggiornaInterfaccia();
        }

        function renderLog() {
            const tabella = document.getElementById('logTabella');
            tabella.innerHTML = `
                <thead><tr><th>Data</th><th>Tipo</th><th>Note</th><th>Prossimo</th></tr></thead>
                <tbody>${appData.logManutenzione.slice(0,5).map(riga => 
                    `<tr><td>${riga.data}</td><td>${riga.tipo}</td><td>${riga.note}</td><td>${riga.prossimo}</td></tr>`
                ).join('')}</tbody>
            `;
        }

        function esportaLog() {
            const csv = 'Data,Tipo,Note,Prossimo\n' + 
                appData.logManutenzione.map(r => `${r.data},"${r.tipo}","${r.note}",${r.prossimo}`).join('\n');
            const blob = new Blob([csv], {type: 'text/csv'});
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url; a.download = `log_acquario_${new Date().toISOString().split('T')[0]}.csv`;
            a.click();
        }

        // Init
        initApp();
        setInterval(aggiornaInterfaccia, 60000); // Aggiorna ogni minuto
    </script>
</body>
</html>
